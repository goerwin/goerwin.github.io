{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": ["**", "!!src/app/apps/grider/**/*.css", "!src/assets/logo.svg"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "warn"
      },
      "suspicious": {
        "noExtraNonNullAssertion": "error",
        "noUnknownAtRules": {
          "level": "warn",
          "options": {
            "ignore": ["tailwind"]
          }
        }
      },
      "nursery": {
        "useSortedClasses": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["public/**/*.svg"],
      "linter": { "enabled": false }
    },
    {
      "includes": ["src/app/cv/styles.css"],
      "linter": {
        "rules": {
          "a11y": {
            "useGenericFontNames": "off"
          }
        }
      }
    }
  ]
}
